# ─── Supabase — "HC Essentials" project (shared with heart-comm-db) ──────────
# This app talks to Supabase only from the server (API route), never from the
# browser, so no NEXT_PUBLIC_* / anon key is needed — just the project URL and
# the service_role key. Find both at: Supabase Dashboard → Project Settings → API
# (same project as heart-comm-db, ref ppxlhmklrzabcgypnbqa).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
